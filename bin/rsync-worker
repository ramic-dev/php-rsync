#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Background worker spawned by SyncQueue::spawnWorker().
 * Usage: php bin/rsync-worker <queue-dir>
 *
 * Before processing jobs, silently checks for a library update.
 * The update runs in this process (already out-of-process from the caller)
 * under a non-blocking exclusive lock, so concurrent workers don't race.
 * Any update failure is swallowed — it never blocks job processing.
 */

$autoload = dirname(__DIR__) . '/vendor/autoload.php';
if (file_exists($autoload)) {
    require $autoload;
} else {
    spl_autoload_register(static function (string $class): void {
        $prefix = 'Ramic\\Rsync\\';
        if (!str_starts_with($class, $prefix)) {
            return;
        }
        $file = dirname(__DIR__) . '/src/' . str_replace('\\', '/', substr($class, strlen($prefix))) . '.php';
        if (file_exists($file)) {
            require_once $file;
        }
    });
}

use Ramic\Rsync\Queue\SyncQueue;
use Ramic\Rsync\Updater;

if ($argc < 2 || trim($argv[1]) === '') {
    fwrite(STDERR, "Usage: rsync-worker <queue-dir>\n");
    exit(1);
}

// ── Auto-update (silent, non-blocking on failure) ─────────────────────────────

try {
    (new Updater())->checkAndUpdate();
} catch (\Throwable) {
    // Never let an update error prevent job processing.
}

// ── Process queued jobs ───────────────────────────────────────────────────────

$queue = new SyncQueue($argv[1]);
$queue->processAll();
