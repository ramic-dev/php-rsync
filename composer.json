{
    "name": "ramic/php-rsync",
    "description": "A pure-PHP implementation of the rsync delta-transfer algorithm. No system binaries required.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ramic\\Rsync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ramic\\Rsync\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
